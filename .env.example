# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# Main app database (the Docker Postgres from docker-compose.yml).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/todoapp

# Separate database the pytest suite uses (created by scripts/init-test-db.sql).
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/todoapp_test

# Needed only for the RAG generation step (POST /rag/ask). Get one from
# https://console.anthropic.com/ . /rag/search works without it.
ANTHROPIC_API_KEY=sk-ant-your-key-here
